# Genovate backend API base URL (FastAPI service)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# WebSocket base URL for real-time dashboard streams
# (CXU / swarm / agent / simulation / program channels are appended to this URL)
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Optional: enable browser desktop notifications for program events
# (still requires user-granted Notification permission at runtime)
NEXT_PUBLIC_ENABLE_DESKTOP_NOTIFICATIONS=false
