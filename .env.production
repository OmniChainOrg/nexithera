# EpistemicOS - REAL MODE
EPISTEMICOS_URL=https://epistemicos.api.nexithera.com
EPISTEMICOS_MOCK_MODE=false
EPISTEMICOS_API_KEY=${EPISTEMICOS_API_KEY}
EPISTEMICOS_TIMEOUT_INGEST=120
EPISTEMICOS_TIMEOUT_SIMULATE=300

# Feature flags
EPISTEMICOS_ENABLE_INGEST=true
EPISTEMICOS_ENABLE_SIMULATION=true
EPISTEMICOS_ENABLE_CXU=true
